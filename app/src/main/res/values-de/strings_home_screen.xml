    <!-- BetaInfoBottomSheet -->
    <string name="beta_sheet_version">Beta 0.7.5</string>
    <string name="beta_sheet_letter">β</string>
    <string name="beta_sheet_welcome_title">Willkommen bei PixelPlayer 0.7.5-beta</string>
    <string name="beta_sheet_welcome_body">Du verwendest eine Beta-Version, die Fehler, Abstürze oder experimentelle Funktionen enthalten kann. Hilf uns bei der Verbesserung, indem du Probleme meldest.</string>
    <string name="beta_sheet_expect_title">Was dich erwartet</string>
    <string name="beta_sheet_expect_1">Fehler, Abstürze oder unvollständige Funktionen können unerwartet auftreten.</string>
    <string name="beta_sheet_expect_2">Einige Funktionen können sich ohne vorherige Ankündigung ändern oder entfernt werden.</string>
    <string name="beta_sheet_expect_3">Beta-Builds können instabiler sein als Release-Versionen.</string>
    <string name="beta_sheet_expect_4">Suche immer nach Updates, bevor du ein bekanntes Problem meldest.</string>
    <string name="beta_sheet_expect_summary">Was Beta-Builds während des Testens ändern, beschädigen oder verbessern können.</string>
    <string name="beta_sheet_github_title">GitHub-Problem-Shortcut</string>
    <string name="beta_sheet_github_body">Suche zuerst nach bestehenden Problemen und öffne dann einen gezielten Bericht für Fehler, Abstürze, Anfragen oder Fragen.</string>
    <string name="beta_sheet_open_issues">GitHub Issues öffnen</string>
    <string name="beta_sheet_report_bug">Fehler oder Absturz melden</string>
    <string name="beta_sheet_report_body">Teile Schritte zur Reproduktion, erwartete Ergebnisse, tatsächliche Ergebnisse sowie Details zu deinem Gerät/Betriebssystem.</string>
    <string name="beta_sheet_report_title">Wie man Probleme meldet</string>
    <string name="beta_sheet_report_summary">Eine kurze Checkliste vor dem Erstellen eines neuen Issues.</string>
    <string name="beta_sheet_before_title">Vor dem Erstellen eines Issues</string>
    <string name="beta_sheet_before_1">Suche in bestehenden offenen und geschlossenen Issues, um Duplikate zu vermeiden.</string>
    <string name="beta_sheet_before_2">Aktualisiere auf die neueste PixelPlayer-Version und bestätige, dass das Problem weiterhin auftritt.</string>
    <string name="beta_sheet_before_3">Starte die App neu und überprüfe, ob das Problem weiterhin besteht.</string>
    <string name="beta_sheet_before_4">Versuche, es zu reproduzieren, und notiere die genauen Schritte.</string>
    <string name="beta_sheet_issue_type_title">Welcher Issue-Typ?</string>
    <string name="beta_sheet_issue_type_bug">Fehlerbericht (Bug report): Etwas verhält sich falsch.</string>
    <string name="beta_sheet_issue_type_feature">Feature-Anfrage: Füge eine neue Funktion oder Verbesserung hinzu.</string>
    <string name="beta_sheet_issue_type_question">Frage: Nutze Diskussionen (Discussions), falls aktiviert, oder öffne ein Issue mit einem Frage-Label.</string>
    <string name="beta_sheet_bug_title">Fehlerbericht</string>
    <string name="beta_sheet_bug_summary_text">Kopiere diese Felder, wenn sich etwas falsch verhält oder abstürzt.</string>
    <string name="beta_sheet_bug_template_title">Fehlerbericht</string>
