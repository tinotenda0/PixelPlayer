    <string name="beta_sheet_bug_frequency">Wie oft tritt es auf? Immer / Manchmal / Selten.</string>
    <string name="beta_sheet_bug_screenshot">Screenshot / Video: falls verfügbar.</string>
    <string name="beta_sheet_bug_logs">Protokolle / Stacktrace: falls verfügbar.</string>
